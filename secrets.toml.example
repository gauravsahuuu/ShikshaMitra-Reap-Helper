# ShikshaMitra Secrets Configuration Template
# Copy this file to .streamlit/secrets.toml and fill in your actual values
# NEVER commit the actual secrets.toml file to git!

# MongoDB Configuration
[mongo]
connection_string = "mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName"
database = "sample_mflix"
collection = "users"
issues_db = "sample_mflix"
issues_collection = "issues"

# Email Configuration (Gmail SMTP)
# Note: Use App Password for Gmail, not your regular password
# https://support.google.com/accounts/answer/185833
[email]
username = "your-email@gmail.com"
password = "your-app-password"
sender = "your-email@gmail.com"

# Chroma Cloud Configuration (Vector Database)
[chroma]
api_key = "your-chroma-api-key"
tenant_id = "your-chroma-tenant-id"
database_id = "your-chroma-database-id"
collection_id = "your-chroma-collection-id"

# Google Gemini API Configuration
[gemini]
api_key = "your-google-gemini-api-key"
